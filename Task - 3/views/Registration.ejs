<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration form</title>
    <link rel="stylesheet" href="/stylesheets/Registration.css">
</head>

<body>
    <nav>
        <h2>EventHub</h2>
        <div class="nav-links">
            <a href="http://localhost:3000/home">Home</a>
            <a href="http://localhost:3000/about">About</a>
            <a href="http://localhost:3000/events">Events</a>
        </div>
    </nav>
    <div class="container">


        <h1> Welcome To Event Form</h1>
        <% if (registrations && registrations._id) { %>
            <!-- <%= JSON.stringify(registrations) %>
            <% console.log(registrations) %> -->
            <form action="/Registration/update/<%= registrations._id %>" method="POST">

                <% } else { %>

                    <form action="/Registration/event" method="POST">

                        <% } %>
                            <% const Pinfo=registrations?.personalInfo || '' %>
                                <% const Cinfo=registrations?.collegeInfo || '' %>
                                    <% const Einfo=registrations?.eventInfo || '' %>

                                        <h3>Your information</h3>

                                        <label for="">Name</label>
                                        <input type="text" id="name" name="name" value="<%= Pinfo.name || '' %>"
                                            placeholder="Enter Your Name">

                                        <label for="">Email</label>
                                        <input type="text" id="email" name="email" value="<%= Pinfo.email || '' %>"
                                            placeholder="you@gmail.com">

                                        <div class="side">

                                            <div class="field">
                                                <label for="">Number</label>
                                                <input type="number" id="number" name="number"
                                                    value="<%= Pinfo.number || '' %>" placeholder="Enter Your Number">
                                            </div>

                                            <div class="field">
                                                <label for="">Age</label>
                                                <input type="number" id="age" name="age" value="<%= Pinfo.age || '' %>"
                                                    placeholder="Enter Your Age">
                                            </div>

                                        </div>

                                        <label for="">Address</label>
                                        <input type="text" id="address" name="address"
                                            value="<%= Pinfo.address || '' %>" placeholder="Enter Your Address">



                                        <!-- Wrap City and State in a side-by-side container -->
                                        <div class="side">

                                            <div class="field">
                                                <label for="city">City</label>
                                                <input type="text" id="city" name="city" value="<%= Pinfo.city || '' %>"
                                                    placeholder="Enter Your City">
                                            </div>

                                            <div class="field">
                                                <label for="state">State</label>
                                                <input type="text" id="state" name="state"
                                                    value="<%= Pinfo.state || '' %>" placeholder="Enter Your State">
                                            </div>

                                        </div>


                                        <div class="section-row">

                                            <div class="section">
                                                <h3>Your's Profession Information</h3>

                                                <label>Your Education</label>
                                                <input type="text" name="education"
                                                    value="<%= Cinfo.education || '' %>">

                                                <label>College</label>
                                                <input type="text" name="college" value="<%= Cinfo.college || '' %>">

                                                <label>Semester</label>
                                                <input type="number" name="semester"
                                                    value="<%= Cinfo.semester || '' %>">

                                                <label>Post</label>
                                                <select name="post">

                                                    <option value="Under Graduation" <%=Cinfo.post==='Under Graduation'
                                                        ? 'selected' : '' %>
                                                        >Under Graduation</option>

                                                    <option value="Post Graduation" <%=Cinfo.post==='Post Graduation'
                                                        ? 'selected' : '' %> >Post
                                                        Graduation</option>

                                                </select>
                                            </div>

                                            <div class="section">
                                                <h3>Registration Information</h3>

                                                <label>Select Event</label>

                                                <% if (event) { %>

                                                    <input type="hidden" name="event" value="<%= event.eventName %>">

                                                    <input type="text" value="<%= event.eventName %>  " selected
                                                        readonly>

                                                    <% } else { %>


                                                        <select name="event" id="event">

                                                            <% events.forEach(ev=>{ %>

                                                                <option value="<%= ev.eventName %>"
                                                                    <%=Einfo.event===ev.eventName ? 'selected' : '' %>>
                                                                    <%= ev.eventName %>
                                                                </option>

                                                                <% }) %>

                                                        </select>

                                                        <% } %>



                                                            <label>Date of Birth</label>
                                                            <input type="date" name="date_of_birth"
                                                                value="<% Einfo.date_of_birth || '' %>">

                                                            <label>Your Role</label>
                                                            <input type="text" name="role"
                                                                value="<% Einfo.role || '' %>">

                                                            <button type="submit">Submit</button>
                                            </div>

                                        </div>

                    </form>
    </div>
</body>

</html>