<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Registrations</title>
    <link rel="stylesheet" href="/stylesheets/MyRegister.css">
</head>

<body>

    <nav>
        <h2>EventHub</h2>

        <div>
            <a href="http://localhost:3000/home">Home</a>
            <a href="http://localhost:3000/events">Events</a>
            <!-- <a href="http://localhost:3000/Registration">Register</a> -->
            <a href="http://localhost:3000/event/myregisters">My Registrations</a>
        </div>
    </nav>

    <main>

        <h1>My Registrations</h1>


        <div class="empty-registration">
            <h3>Find Your Registration details Here</h3>

            <form action="http://localhost:3000/event/myregisters">

                <label for="search">Search:</label>

                <input type="text" name="search" id="search" placeholder="Enter Your Email">

                <button type="submit">
                    Search Here
                </button>

            </form>
            <% if (message) { %>

                <div class="message">
                    <h3>
                        <%= message %>
                    </h3>
                </div>

                <% } %>

                    <% if (registrations.length> 0) { %>

                        <div class="registration-container">

                            <% registrations.forEach(registration=> { %>

                                <div class="registration-card">

                                    <h2>
                                        <%= registration.personalInfo.name %>
                                    </h2>

                                    <p>
                                        <strong>Email:</strong>
                                        <%= registration.personalInfo.email %>
                                    </p>

                                    <p>
                                        <strong>Phone:</strong>
                                        <%= registration.personalInfo.number %>
                                    </p>

                                    <p>
                                        <strong>Age:</strong>
                                        <%= registration.personalInfo.age %>
                                    </p>

                                    <p>
                                        <strong>Address:</strong>
                                        <%= registration.personalInfo.address %>
                                    </p>

                                    <p>
                                        <strong>Event:</strong>
                                        <%= registration.eventInfo.event %>
                                    </p>
                                    <button>

                                        <a href="http://localhost:3000/Registration/edit/<%= registration._id %>">
                                            Update Registration
                                        </a>
                                    </button>
                                    <button>

                                        <a
                                            href="http://localhost:3000/Registration/delete/<%= registration.personalInfo.email%>">
                                            Cancel Registration
                                        </a>
                                    </button>

                                </div>

                                <% }) %>

                        </div>

                        <% } %>

    </main>

</body>

</html>